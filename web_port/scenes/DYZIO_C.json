    "rawText": "//###########################################################################\n\n//Script code\n\n//###########################################################################\n\n\n\n\n\nOnOpenPage()\n\n{\n\n\t// Add your component and variables initialization code here\n\n\t// WARNING: All variables definied on this function are global for this page\n\n   // ID dzwiekow w grupie\n\n   // 0 - pomoc\n\n   // 1 - prawidlowo\n\n   // 2 - nieprawidlowo\n\n   // 3 - wszystkie prawidlowo\n\n   // 4 - wszystkie blednie\n\n\n\n\n\n   int roznice[10];\n\n   int blad = 0;\n\n   int poprawnie = 0;\n\n\n\n   Sprite_Holder.MoveTo( 1, 193, 301 );\n\n   Sprite_Holder.MoveTo( 2, 505, 16 );\n\n   Sprite_Holder.MoveTo( 3, 111, 153 );\n\n   Sprite_Holder.MoveTo( 4, 278, 3 );\n\n   Sprite_Holder.MoveTo( 5, 344, 75 );\n\n   Sprite_Holder.MoveTo( 6, 151, 350 );\n\n   Sprite_Holder.MoveTo( 7, 244, 271 );\n\n   Sprite_Holder.MoveTo( 8, 53, 5 );\n\n   Sprite_Holder.MoveTo( 9, 486, 100 );\n\n   Sprite_Holder.MoveTo( 10, 218, 114 );\n\n   Sprite_Holder.MoveTo( 11, 193, 301 );\n\n   Sprite_Holder.MoveTo( 12, 505, 16 );\n\n   Sprite_Holder.MoveTo( 13, 111, 153 );\n\n   Sprite_Holder.MoveTo( 14, 278, 3 );\n\n   Sprite_Holder.MoveTo( 15, 344, 75 );\n\n   Sprite_Holder.MoveTo( 16, 151, 350 );\n\n   Sprite_Holder.MoveTo( 17, 244, 271 );\n\n   Sprite_Holder.MoveTo( 18, 53, 5 );\n\n   Sprite_Holder.MoveTo( 19, 486, 100 );\n\n   Sprite_Holder.MoveTo( 20, 218, 114 );\n\n\n\n\n\n   LoadGroup(\"gr_czym.grp\");\n\n\n\n   Group.Sound_Holder.PlayDSound(10);\n\n\n\n   int toolbar=0;\n\n   int toolbarCase=0;\n\n   Group.HotSpot_Holder.DisableHotSpot(12);\n\n\n\n   SetCursor(1);\n\n   //SetTimer( 5000 );\n\n   FadeScreen( 1, 1000 );\n\n}\n\n\n\n\n\nvoid OnClosePage(void)\n\n{\n\n\t// Add your close page handler code here\n\n   FadeScreen(0,1000);\n\n}\n\n\n\n\n\n \n\n/////////////////////////////////////////////////////////////////////\n\n//\n\n// \n\nvoid OnTimer(void)\n\n{\n\n        //Add your command handler code here\n\n   SetTimer(0);\n\n   Group.Sound_Holder.PlayDSound(0);\n\n}\n\n \n\n\n\n\n\n///////////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid OnLButtonDown(int x,int y)\n\n{\n\n        //Add your command handler code here\n\n   SetTimer(0);\n\n   Group.Sound_Holder.Stop(0);\n\n}\n\n \n\n\n\n\n\n/////////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid OnRButtonDown(int x,int y)\n\n{\n\n        //Add your command handler code here\n\n   SetTimer(0);\n\n   Group.Sound_Holder.PlayDSound(0);\n\n}\n\n \n\n\n\n\n\n\n\n\n\n\n\n/////////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid Group.HotSpot_Holder.MouseMoveIn(int rectID)\n\n{\n\n   switch( rectID )\n\n   {\n\n      case 0:   // wysuniecie poprawnej strony\n\n         SetCursor(0);\n\n         SetTimer(0);\n\n         Group.Sound_Holder.Stop(0);\n\n\n\n         Sprite_Holder.GotoXY( 0, 40, 0 );\n\n         Group.Sound_Holder.Stop(9);\n\n         Group.Sound_Holder.PlayDSound(8);\n\n\n\n         break;\n\n      case 11:   //wysun toolbar\n\n         Group.Sprite_Holder.DisableTimers();\n\n\n\n         Group.Sprite_Holder.GotoXY(15,480,0);\n\n         Group.Sprite_Holder.GotoXY(16,560,329);\n\n         Group.Sprite_Holder.GotoXY(17,557,404);\n\n         Group.Sprite_Holder.GotoXY(18,544,14);\n\n         Group.Sprite_Holder.GotoXY(19,584,14);\n\n\n\n         Group.Sprite_Holder.SynchronizeTimers();\n\n         Group.Sprite_Holder.EnableTimers();\n\n         Group.Sound_Holder.PlayDSound(5);\n\n         SetCursor(0);\n\n         break;\n\n      case 12:\n\n         SetCursor(1);\n\n         if(toolbar)\n\n         {\n\n            Group.Sprite_Holder.DisableTimers();\n\n\n\n            Group.Sprite_Holder.GotoXY(15,640,0);\n\n            Group.Sprite_Holder.GotoXY(16,721,329);\n\n            Group.Sprite_Holder.GotoXY(17,717,404);\n\n            Group.Sprite_Holder.GotoXY(18,704,14);\n\n            Group.Sprite_Holder.GotoXY(19,744,14);\n\n\n\n            Group.Sprite_Holder.SynchronizeTimers();\n\n            Group.Sprite_Holder.EnableTimers();\n\n            Group.Sound_Holder.PlayDSound(5);\n\n            toolbar=0;\n\n         }\n\n         Group.HotSpot_Holder.DisableHotSpot(12);\n\n         break;\n\n   }\n\n}\n\n\n\n \n\nvoid Group.HotSpot_Holder.MouseMoveOut(int rectID)\n\n{\n\n   switch( rectID )\n\n   {\n\n      case 0:   // wsuniecie poprawnej strony\n\n         Sprite_Holder.GotoXY( 0, 40, -420 );\n\n         Group.Sound_Holder.Stop(8);\n\n         Group.Sound_Holder.PlayDSound(9);\n\n\n\n         break;\n\n   }\n\n}\n\n\n\n \n\n\n\n/////////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid Sprite_Holder.MouseClickOnDown(int spriteID)\n\n{\n\n   if( (spriteID >= 1) && (spriteID <= 10) )\n\n   {\n\n      int sprite = spriteID-1;\n\n      if( roznice[sprite] == 0 )\n\n      {\n\n         roznice[sprite]=1;\n\n         Group.Sound_Holder.PlayDSound(1);\n\n         Sprite_Holder.ShowSprite(spriteID+10);\n\n         Sprite_Holder.HideSprite(spriteID);\n\n\n\n         //Sprite_Holder.ChangePhase( spriteID, 1 );\n\n\n\n         Group.Sprite_Holder.ChangePhase( poprawnie, 1 );\n\n         poprawnie++;\n\n\n\n         if( poprawnie >= 10 )\n\n         {\n\n            Group.Sound_Holder.PlayDSound(3);\n\n         }\n\n      }\n\n      \n\n   }\n\n}\n\n\n\n \n\n\n\n///////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid Bitmap_Holder.MouseMoveIn(int bitmapID)\n\n{\n\n   SetCursor(1);\n\n}\n\n\n\n \n\nvoid Bitmap_Holder.MouseMoveOut(int bitmapID)\n\n{\n\n   SetCursor(0);\n\n}\n\n\n\n \n\n\n\n///////////////////////////////////////////////////////////////\n\n//\n\n//\n\nvoid Bitmap_Holder.MouseClickOnDown(int bitmapID)\n\n{\n\n   switch( bitmapID )\n\n   {\n\n      case 0: // blad\n\n         if( poprawnie >= 10 ) return;\n\n\n\n         Group.Sound_Holder.PlayDSound(2);\n\n         Group.Sprite_Holder.ChangePhase( blad+10, 1 );\n\n         blad++;\n\n\n\n         if( blad >= 5 )\n\n         {\n\n            // Popelniono 5 bledow - reset\n\n            Group.Sound_Holder.PlayDSound(4);\n\n\n\n            blad = 0;\n\n            poprawnie = 0;\n\n\n\n            int index = 0;\n\n            while( index < 10 )\n\n            {\n\n               roznice[index]=0;\n\n               Group.Sprite_Holder.ChangePhase( index, 0 );\n\n               if( index < 5 )\n\n                  Group.Sprite_Holder.ChangePhase( index+10, 0 );\n\n               //Sprite_Holder.ChangePhase( index+1, 0 );\n\n               Sprite_Holder.HideSprite( index+11 );\n\n               Sprite_Holder.ShowSprite( index+1 );\n\n               index++;\n\n            }\n\n         }\n\n   }\n\n}\n\n\n\n\n\n//############################################################# T O O L B A R #######\n\n//#############################################################---------------#######\n\n\n\nvoid Group.Sprite_Holder.MouseClickOnDown(int spriteID)\n\n{\n\n   if(spriteID>15)\n\n   {\n\n      Group.Sprite_Holder.ChangePhase(spriteID,1);\n\n      switch(spriteID)\n\n      {\n\n         case 16:\n\n            Group.Sound_Holder.PlayDSound(6);\n\n            break;\n\n         case 17:\n\n            Group.Sound_Holder.PlayDSound(7);\n\n            break;\n\n         case 18:   //parent window\n\n            Group.Sound_Holder.PlayDSound(11);\n\n            break;\n\n         case 19:   //plansza glowna\n\n            Group.Sound_Holder.PlayDSound(12);\n\n            break;\n\n      }\n\n      Group.Sprite_Holder.DisableTimers();\n\n\n\n      Group.Sprite_Holder.GotoXY(15,640,0);\n\n      Group.Sprite_Holder.GotoXY(16,721,329);\n\n      Group.Sprite_Holder.GotoXY(17,717,404);\n\n      Group.Sprite_Holder.GotoXY(18,704,14);\n\n      Group.Sprite_Holder.GotoXY(19,744,14);\n\n\n\n      Group.Sprite_Holder.SynchronizeTimers();\n\n      Group.Sprite_Holder.EnableTimers();\n\n      Group.Sound_Holder.PlayDSound(5);\n\n      toolbar=0;\n\n      Group.HotSpot_Holder.DisableHotSpot(11);\n\n      toolbarCase=spriteID;\n\n   }\n\n}\n\n\n\n\n\nvoid Group.Sprite_Holder.InPlace(int spriteID,int x,int y)\n\n{\n\n   if(spriteID==15)\n\n   {\n\n      if(x==480)\n\n      {\n\n         toolbar=1;\n\n         Group.HotSpot_Holder.EnableHotSpot(12);\n\n         SetCursor(0);\n\n      }\n\n      else\n\n      {\n\n         Group.Sprite_Holder.ChangePhase(16,0);\n\n         Group.Sprite_Holder.ChangePhase(17,0);\n\n         Group.Sprite_Holder.ChangePhase(18,0);\n\n         Group.Sprite_Holder.ChangePhase(19,0);\n\n         switch(toolbarCase)\n\n         {\n\n            case 18:\t//lewo\n\n               if(IsProject())   parentWnd.SetString(\"mich0.bdf\");\n\n               LoadPage(\"michal_c.bdf\");\n\n               break;\n\n            case 19:\t//prawo\n\n               LoadPage(\"figiel_c.bdf\");\n\n               break;\n\n            case 16:   //do planszy glownej   \n\n               LoadPage( \"dyzio.bdf\" );\n\n               break;\n\n            case 17:   //Plansza wyboru\n\n               LoadPage(\"Wyborw.bdf\");\n\n               break;\n\n         }\n\n      }\n\n   }\n\n}\n\n\n\nvoid Group.Sprite_Holder.MouseMoveIn(int spriteID)\n\n{\n\n   if(spriteID>15)   SetCursor(1);\n\n\n\n}\n\n\n\n \n\nvoid Group.Sprite_Holder.MouseMoveOut(int spriteID)\n\n{\n\n   if(spriteID>15)   SetCursor(0);\n\n}\n\n\n\n//#############################################################\n\n//############################################################# \n\n \n\n  "
  },
